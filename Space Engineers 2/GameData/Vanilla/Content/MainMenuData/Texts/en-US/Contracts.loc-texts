  "BlankText": "",
  "SpaceIntroductionTitle": "A place to call home",
  "SpaceIntroductionDesc": "Someone started making an outpost on a nearby asteroid. If you finish constructing a few essential blocks it's yours!",
  "SpaceAbandonedResearchOutpostRepairTitle": "Engineering - Abandoned Research Outpost",
  "SpaceAbandonedResearchOutpostDesc": "A deep-space research outpost stopped broadcasting for some reason. The station may still be intact, but its systems need restoration. Investigate the site, bring it back online, and secure its stored data.",
  "SpaceBasedLostAsteroidEngineeringTitle": "Engineering - Lost Asteroid Base",
  "SpaceBasedLostAsteroidEngineeringDesc": "A novice engineer was building an asteroid base but lost its exact location while searching for building materials. Find the base located somewhere around the coordinates and finish constructing it.",
  "SpaceBasedRenegadeHideoutTitle": "Sabotage - Renegade Hideout",
  "SpaceBasedRenegadeHideoutDesc": "There is a renegade hideout somewhere in the asteroid field. Locate and neutralize the hideout by getting rid of their power generation systems. Naturally they don't have an antenna to broadcast their location but we have information that the hideout is near iron ore deposit. ",
  "PlanetBasedSupplyBaseTitle": "Hauling - Supply Base",
  "PlanetBasaedSupplyBaseDesc": "Accident left multiple containers scattered around a supply base. Build a small tug ship and move those containers inside the storage hall.",
  "PlanetBasedManufacturingFacilityTitle": "Engineering - Manufacturing Facility",
  "PlanetBasedManufacturingFacilityDesc": "We are looking to build an manufacturing facility on Verdure. Finish construction of the site.",
  "PlanetBasedExcavationSiteTitle": "Engineering - Excavation Site",
  "PlanetBasedExcavationSiteDesc": "Our exploration team has found an interesting natural cave formation we want to explore further. We set up some excavation sites and need you to finalize them.",
  "SpaceBasedCommStationUpgradeTitle": "Engineering - Comm Station Upgrade",
  "SpaceBasedCommStationUpgradeDesc": "We are upgrading our communications station to enable connection to the other station's on the fast travel network. Please find the station, and finish construction of the relay stations around the asteroid. Once this is completed you should spend some time building for yourself while you wait for the other sectors to get their upgrades done.",
  "SpaceBasedHydrogenProductionFacilityTitle": "Engineering - Hydrogen Production Facility",
  "SpaceBasedHydrogenProductionFacilityDesc": "A critical hydrogen production facility in the sector sustained damage. Resume the hydrogen production by repairing the damaged conveyor lines and hydrogen tanks.",
  "SpaceBasedDetonationDetectedTitle": "Engineering - Detonation Detected",
  "SpaceBasedDetonationDetectedDesc": "An explosion has been detected at a nearby outpost, go check it out and offer assistance.",
  "SpaceBasedStrandedFreighterTitle": "Hauling - Stranded Freighter",
  "SpaceBasedStrandedFreighterDesc": "A large ship has lost its cargo when colliding with an asteroid, find the cargo and deliver it to the nearby outpost.",
  "SpaceBasedUraniumMineAccidenttitle": "Engineering - Uranium Mine Accident",
  "SpaceBasedUraniumMineAccidentDesc": "Uranium mine was being upgraded with a reactor when a power surge damaged electrical systems across the facility. Repair the damaged systems, build the reactor and search the mine for some uranium to fuel it.",
  "SpaceBasedAsteroidExpeditionTitle": "Engineering - Asteroid Expedition",
  "SpaceBasedAsteroidExpeditionDesc": "Science team found an interesting asteroid presumed to be hollow inside. Help them build a mining ship to reach the center and assist with any other tasks they have for you.",
  "SpaceBasedSectorFoundationsTitle": "Engineering - Sector Foundations",
  "SpaceBasedShipBreakersTitle": "Salvage - Ship Breakers",
  "APlaceToCallHomeObj1Title": "Objective 1: A Place to Call Home",
  "APlaceToCallHomeObj1Desc": "There is a platform on a nearby asteroid that you can build your own outpost on. Travel to the marker indicated on your HUD",
  "APlaceToCallHomeObj1aDesc": "• Finish constructing the survival kit and register it as your home base",
  "APlaceToCallHomeObj1bDesc": "• Repair the antenna to help find your way back to it later on",
  "APlaceToCallHomeObj1cDesc": "• Repair the Ore Detector to see the nearby ore deposits",
